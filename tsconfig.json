{
     "compilerOptions": {
         "target": "es5",
         "jsx": "preserve",
         "module": "commonjs",
         "moduleResolution": "node",
         "esModuleInterop": true,
         "strict": true,
         "skipLibCheck": true,
         "paths": {
             "@/*": ["apps/web/src/*"]
          }
       },
     "references": [
         { "path": "apps/web" }
       ]
}
